APP_PORT=8081
APP_ADDRESS=0.0.0.0

# MySQL
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/ollama_chat?useSSL=false&serverTimezone=UTC&characterEncoding=utf8
MYSQL_USER=root
MYSQL_PASSWORD=change-me

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Chroma（可选）
CHROMA_BASE_URL=http://127.0.0.1:8000

# Ollama（本地大模型）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_CHAT_MODEL_SMALL=qwen3.5:0.8b
OLLAMA_CHAT_MODEL_MEDIUM=qwen3.5:2b
OLLAMA_CHAT_MODEL_LARGE=qwen3.5:4b

# BigModel（智谱AI，用于题目生成）
# 可通过环境变量 BIGMODEL_API_KEY 配置，或在此处设置
# BIGMODEL_API_KEY=your_api_key_here

# CORS（当你的前端域名与后端不同源时使用）
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

